rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if request.resource.data.slug is string && request.resource.data.slug.size() > 0;
      allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "ismailbanouigu@gmail.com" && request.auth.token.email_verified == true;
    }

    match /drafts/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
